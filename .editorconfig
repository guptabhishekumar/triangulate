root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,yml,yaml,json,toml}]
indent_size = 2

[*.ps1]
end_of_line = crlf

[*.{mq5,mqh}]
end_of_line = crlf
indent_size = 3

[*.csv]
trim_trailing_whitespace = false
insert_final_newline = false
